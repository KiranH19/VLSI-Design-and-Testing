`timescale 1ns/1ps // Define time unit and precision
module tb_shift_add_multiplier;
 // Testbench signals
 reg [3:0] a_tb;
 reg [3:0] b_tb;
 wire [7:0] product_tb;
 // Instantiate the design under test (DUT)
 shift_add_multiplier dut (
 .a(a_tb),
 .b(b_tb),
 .product(product_tb)
 );
 initial begin
 // Display header
 $display("Time\t a\t b\t | product (Binary) | Product (Decimal)");
 $display("------------------------------------------------------");
 // Test cases
 a_tb = 4'b0000; b_tb = 4'b0000; #10;

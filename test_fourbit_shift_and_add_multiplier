 a_tb = 4'b0001; b_tb = 4'b0001; #10;
 $display("%0dns:\t %b\t %b\t | %b\t | %0d", $time, a_tb, b_tb, product_tb, product_tb);
 a_tb = 4'b0010; b_tb = 4'b0011; #10;
 $display("%0dns:\t %b\t %b\t | %b\t | %0d", $time, a_tb, b_tb, product_tb, product_tb);
 a_tb = 4'b1010; b_tb = 4'b0011; #10;
 $display("%0dns:\t %b\t %b\t | %b\t | %0d", $time, a_tb, b_tb, product_tb, product_tb);
 a_tb = 4'b1111; b_tb = 4'b1111; #10;
 $display("%0dns:\t %b\t %b\t | %b\t | %0d", $time, a_tb, b_tb, product_tb, product_tb);

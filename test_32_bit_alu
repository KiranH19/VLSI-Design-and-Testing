// Testbench Code

`timescale 1ns/1ps

module alu_bit_tb;

reg [31:0] A;
reg [31:0] B;
reg [3:0] ALU_Sel;

wire [31:0] ALU_Out;
wire Zero;

// Instantiate ALU

alu_bit dut (
.A(A),
.B(B),
.ALU_Sel(ALU_Sel),
.ALU_Out(ALU_Out),
.Zero(Zero)
);

initial
begin

A = 32'd15;
B = 32'd5;

// Addition
#10 ALU_Sel = 4'b0000;

// Subtraction
#10 ALU_Sel = 4'b0001;

// AND
#10 ALU_Sel = 4'b0010;

// OR
#10 ALU_Sel = 4'b0011;

// XOR
#10 ALU_Sel = 4'b0100;

// NEGATION
#10 ALU_Sel = 4'b0101;

// LEFT SHIFT
#10 ALU_Sel = 4'b0110;

// RIGHT SHIFT
#10 ALU_Sel = 4'b0111;

// LESS THAN
#10 ALU_Sel = 4'b1000;

#20 $finish;

end

initial
begin

$monitor("Time=%0t ALU_Sel=%b A=%d B=%d ALU_Out=%d Zero=%b",
          $time, ALU_Sel, A, B, ALU_Out, Zero);

end

endmodule

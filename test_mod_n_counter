module tb_mod_n_counter;

 reg clk; // Clock signal
 reg rst_n; // Asynchronous reset (active low)
 reg [3:0] N; // Modulus value
 wire [3:0] count; // Counter output
 // Instantiate the mod_n_counter module
 mod_n_counter uut (
 .clk(clk),
 .rst_n(rst_n),
 .N(N),
 .count(count)
 );

 // Clock generation
 always begin
 #5 clk = ~clk; // Toggle clock every 5 time units
 end

 // Test procedure
 initial begin
 clk = 0; // Initialize clock
 rst_n = 0; // Apply reset
 N = 4; // Set modulus to 4

 // Apply reset
 #10 rst_n = 1; // Release reset after 10 time units

 // Test mod 4 counter
 #40;

 // Change modulus to 6
 N = 6;
 #40;
 // Test mod 8 counter
 N = 8;
 #80;
// Test mod 10 counter
 N = 10;
 #100;

 // End simulation
 $finish;
 end
 // Monitor the output
 initial begin
 $monitor("Time=%0t, clk=%b, rst_n=%b, N=%d, count=%d", $time, clk, rst_n, N,
count);
 end
endmodule
